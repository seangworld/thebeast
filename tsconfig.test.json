{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "target": "es2020",
    "tsBuildInfoFile": ".test-dist/tsconfig.test.tsbuildinfo"
  },
  "include": ["src/lib/velocity/**/*.ts", "tests/**/*.test.ts"],
  "exclude": ["node_modules", ".next", ".test-dist"]
}
